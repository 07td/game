{
  "ts-node": {
    "esm": true,
    "files": true,
    "compilerOptions": {
      "module": "nodenext",
    }
  },
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext",
      "ES2020"
    ],
    "types": ["@webgpu/types"],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx"
    "baseUrl": ".",
    "paths": {
      "@rs-map-viewer/mapviewer/*": ["src/lib/mapviewer/*"],
      "@rs-map-viewer/rs/*": ["src/rs/*"],
      "@rs-map-viewer/towerdefense/*": ["src/towerdefense/*"]
    }
  },
  "include": [
    "src", "scripts"
  ]
}
