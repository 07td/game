{
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
        "dom",
        "dom.iterable",
        "es2020"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "types": ["@webgpu/types"],
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "downlevelIteration": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@rs-map-viewer/mapviewer/*": ["../src/lib/mapviewer/*"],
      "@rs-map-viewer/rs/*": ["../src/rs/*"],
      "@rs-map-viewer/towerdefense/*": ["../src/towerdefense/*"]
    }
  },
  "include": [
    "src",
    "../src"
  ]
}
